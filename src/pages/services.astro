---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ServiceCard from '../components/ServiceCard.astro';
import '../styles/global.css';

// Comprehensive service categories
const serviceCategories = [
  {
    category: "Body & Paint Services",
    services: [
      {
        icon: "🎨",
        title: "Denting & Painting",
        description: "Expert dent removal and premium quality painting using the latest color matching technology. Restore your vehicle to showroom condition."
      },
      {
        icon: "🌈",
        title: "Color Change",
        description: "Complete vehicle color transformation with high-quality automotive paint. Professional application ensures long-lasting results."
      },
      {
        icon: "🧽",
        title: "Color Removal",
        description: "Safe and effective paint removal services for restoration or color change projects."
      },
      {
        icon: "🏗️",
        title: "Custom Body Kits",
        description: "Design and installation of custom body kits to enhance your vehicle's appearance and aerodynamics."
      },
      {
        icon: "🔨",
        title: "Custom-Made Body Parts",
        description: "Fabrication of custom body parts tailored to your specific requirements and design preferences."
      }
    ]
  },
  {
    category: "Mechanical Services",
    services: [
      {
        icon: "🔧",
        title: "Mechanical Repairs",
        description: "Comprehensive mechanical diagnostics and repairs. From engine issues to transmission problems, we handle it all."
      },
      {
        icon: "🔩",
        title: "New Parts Installation",
        description: "Professional installation of new parts and accessories. Genuine and aftermarket parts available."
      },
      {
        icon: "🏁",
        title: "Engine Tuning",
        description: "Performance engine tuning and optimization for improved power, efficiency, and driving experience."
      },
      {
        icon: "🛞",
        title: "Custom Suspension Setups",
        description: "Specialized suspension modifications and tuning for improved handling and ride comfort."
      }
    ]
  },
  {
    category: "Specialized Services",
    services: [
      {
        icon: "⚡",
        title: "Welding Services",
        description: "Professional welding and metal fabrication for structural repairs and custom modifications."
      },
      {
        icon: "💡",
        title: "Electrical Work",
        description: "Complete electrical system diagnostics, repairs, and custom wiring for accessories and modifications."
      },
      {
        icon: "❄️",
        title: "AC Works",
        description: "Air conditioning service, repairs, gas refill, and complete AC system overhaul."
      },
      {
        icon: "🔊",
        title: "Custom Exhausts",
        description: "Custom exhaust system design and installation for improved performance and sound."
      }
    ]
  },
  {
    category: "Detailing & Protection",
    services: [
      {
        icon: "✨",
        title: "Washing & Polishing",
        description: "Premium car wash and professional polishing services. Deep cleaning for interior and exterior."
      },
      {
        icon: "🛡️",
        title: "Teflon Coating",
        description: "Advanced Teflon protective coating for paint protection, UV resistance, and easy maintenance."
      }
    ]
  },
  {
    category: "Custom Modifications",
    services: [
      {
        icon: "🏎️",
        title: "Custom Modding",
        description: "Complete custom modification services including body kits, performance upgrades, and aesthetic enhancements."
      },
      {
        icon: "🎨",
        title: "Custom Bodyworks",
        description: "Expert body modifications and customization to create your dream vehicle."
      }
    ]
  },
  {
    category: "Additional Services",
    services: [
      {
        icon: "🏠",
        title: "Household Item Repainting",
        description: "Professional repainting services for house almirahs, cabinets, and other household metal items."
      }
    ]
  }
];
---

<BaseLayout 
  title="Our Services | Warsi Service Center"
  description="Comprehensive automobile services including denting, painting, mechanical repairs, custom modding, AC works, and more for cars, bikes, and scooters."
  currentPath="/services"
>
  <Header />
  
  <!-- Hero Section -->
  <section class="relative pt-32 pb-16 overflow-hidden">
    <div class="absolute inset-0 grid-pattern opacity-40"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent to-workshop-darker"></div>
    
    <div class="container-custom px-4 relative z-10">
      <div class="max-w-3xl mx-auto text-center">
        <div class="inline-block accent-line mb-6"></div>
        <h1 class="text-5xl md:text-6xl font-display font-bold text-white mb-6 animate-fade-in">
          Our <span class="gradient-text">Services</span>
        </h1>
        <p class="text-xl text-gray-400 mb-8 animate-fade-in">
          Comprehensive automobile solutions for cars, bikes, and scooters
        </p>
        <p class="text-gray-400 max-w-2xl mx-auto animate-fade-in">
          From routine maintenance to custom modifications, we provide professional services with guaranteed quality. Our experienced team handles every job with precision and care.
        </p>
      </div>
    </div>
  </section>

  <!-- Services Grid by Category -->
  {serviceCategories.map((category, idx) => (
    <section class={`section ${idx % 2 === 0 ? 'bg-workshop-darker' : 'bg-workshop-dark'}`}>
      <div class="container-custom px-4">
        <div class="mb-12 animate-on-scroll">
          <h2 class="text-3xl md:text-4xl font-display font-bold text-white mb-3">
            {category.category}
          </h2>
          <div class="w-16 h-1 bg-accent-navy rounded-full"></div>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {category.services.map((service) => (
            <ServiceCard 
              icon={service.icon}
              title={service.title}
              description={service.description}
            />
          ))}
        </div>
      </div>
    </section>
  ))}

  <!-- Vehicle Types Section -->
  <section class="section bg-workshop-gray">
    <div class="container-custom px-4">
      <div class="text-center mb-12">
        <div class="inline-block accent-line mb-4"></div>
        <h2 class="text-4xl md:text-5xl font-display font-bold text-white mb-4">
          We Service All <span class="gradient-text">Vehicles</span>
        </h2>
        <p class="text-gray-400 max-w-2xl mx-auto">
          Professional service for every type of vehicle
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto">
        <div class="card card-hover text-center animate-on-scroll">
          <div class="text-6xl mb-4">🚗</div>
          <h3 class="font-display text-2xl font-semibold text-white mb-2">Cars</h3>
          <p class="text-gray-400">All makes and models of cars serviced with expert care</p>
        </div>

        <div class="card card-hover text-center animate-on-scroll" style="animation-delay: 0.1s;">
          <div class="text-6xl mb-4">🏍️</div>
          <h3 class="font-display text-2xl font-semibold text-white mb-2">Bikes</h3>
          <p class="text-gray-400">Professional motorcycle service and custom modifications</p>
        </div>

        <div class="card card-hover text-center animate-on-scroll" style="animation-delay: 0.2s;">
          <div class="text-6xl mb-4">🛵</div>
          <h3 class="font-display text-2xl font-semibold text-white mb-2">Scooters</h3>
          <p class="text-gray-400">Complete scooter maintenance and repair services</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Process Section -->
  <section class="section bg-workshop-darker">
    <div class="container-custom px-4">
      <div class="text-center mb-16">
        <div class="inline-block accent-line mb-4"></div>
        <h2 class="text-4xl md:text-5xl font-display font-bold text-white mb-4">
          Our <span class="gradient-text">Process</span>
        </h2>
        <p class="text-gray-400 max-w-2xl mx-auto">
          Simple and transparent service process
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-4 gap-8 max-w-6xl mx-auto">
        <div class="text-center animate-on-scroll">
          <div class="w-16 h-16 bg-accent-navy rounded-full flex items-center justify-center mx-auto mb-4 text-2xl font-display font-bold text-white">
            1
          </div>
          <h3 class="font-display text-xl font-semibold text-white mb-2">Contact Us</h3>
          <p class="text-gray-400 text-sm">Call or visit us with your vehicle service needs</p>
        </div>

        <div class="text-center animate-on-scroll" style="animation-delay: 0.1s;">
          <div class="w-16 h-16 bg-accent-navy-light rounded-full flex items-center justify-center mx-auto mb-4 text-2xl font-display font-bold text-white">
            2
          </div>
          <h3 class="font-display text-xl font-semibold text-white mb-2">Inspection</h3>
          <p class="text-gray-400 text-sm">Thorough vehicle inspection and diagnosis</p>
        </div>

        <div class="text-center animate-on-scroll" style="animation-delay: 0.2s;">
          <div class="w-16 h-16 bg-accent-steel rounded-full flex items-center justify-center mx-auto mb-4 text-2xl font-display font-bold text-white">
            3
          </div>
          <h3 class="font-display text-xl font-semibold text-white mb-2">Service</h3>
          <p class="text-gray-400 text-sm">Professional service by experienced technicians</p>
        </div>

        <div class="text-center animate-on-scroll" style="animation-delay: 0.3s;">
          <div class="w-16 h-16 bg-accent-navy rounded-full flex items-center justify-center mx-auto mb-4 text-2xl font-display font-bold text-white">
            4
          </div>
          <h3 class="font-display text-xl font-semibold text-white mb-2">Delivery</h3>
          <p class="text-gray-400 text-sm">Quality check and vehicle delivery</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="section bg-workshop-dark">
    <div class="container-custom px-4">
      <div class="max-w-4xl mx-auto text-center card glow-orange p-12 animate-on-scroll">
        <h2 class="text-3xl md:text-4xl font-display font-bold text-white mb-4">
          Need Professional Service?
        </h2>
        <p class="text-gray-400 mb-8 max-w-2xl mx-auto">
          Get in touch with us today. Our team is ready to help you with any automobile service needs.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="tel:9756544613" class="btn btn-primary text-lg">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Call 9756544613
          </a>
          <a href="/contact" class="btn btn-secondary text-lg">
            Contact Us
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

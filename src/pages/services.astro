---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { CyberneticBentoGrid } from '@/components/ui/cybernetic-bento-grid';
import { FloatingNavDemo } from '@/components/ui/floating-navbar';
import { Footer } from '@/components/ui/large-name-footer';
import { PageLoadingOverlay } from '@/components/ui/page-loading-overlay';
---

<BaseLayout
  title="Automobile Services | Denting Painting Mechanical AC Repair | Warsi Service Center"
  description="Complete automobile services: denting and painting, mechanical repairs, welding, washing and polishing, teflon coating, electrical work, custom modding, suspension setup, color change, AC works, and engine tuning for cars, bikes, and scooters."
  keywords="denting service, painting service, mechanical repair, welding service, car wash, polishing, teflon coating, electrical repair, custom modification, body kit, suspension, color change, AC repair, engine tuning, custom exhaust, bodywork, scooter repair, bike repair, car service"
  canonicalPath="/services"
>
  <main class="min-h-screen bg-hero-wash">
    <PageLoadingOverlay client:load />
    <FloatingNavDemo client:load />
    <CyberneticBentoGrid client:load />

    <section class="px-4 pb-4 pt-6 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-6xl rounded-3xl border border-neutral-200 bg-white/90 p-6 shadow-sm sm:p-8">
        <p class="text-sm font-medium uppercase tracking-[0.22em] text-neutral-500">Process</p>
        <h2 class="mt-3 text-2xl font-semibold text-neutral-900 sm:text-3xl">How service moves from enquiry to delivery</h2>
        <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-4">
          <div class="rounded-2xl border border-neutral-200 bg-neutral-50 p-4">
            <p class="text-xs uppercase tracking-[0.16em] text-neutral-500">01</p>
            <h3 class="mt-1 text-base font-semibold text-neutral-900">Contact Us</h3>
            <p class="mt-2 text-sm text-neutral-600">Call or visit us with your vehicle service needs.</p>
          </div>
          <div class="rounded-2xl border border-neutral-200 bg-neutral-50 p-4">
            <p class="text-xs uppercase tracking-[0.16em] text-neutral-500">02</p>
            <h3 class="mt-1 text-base font-semibold text-neutral-900">Inspection</h3>
            <p class="mt-2 text-sm text-neutral-600">Thorough vehicle inspection and diagnosis.</p>
          </div>
          <div class="rounded-2xl border border-neutral-200 bg-neutral-50 p-4">
            <p class="text-xs uppercase tracking-[0.16em] text-neutral-500">03</p>
            <h3 class="mt-1 text-base font-semibold text-neutral-900">Service</h3>
            <p class="mt-2 text-sm text-neutral-600">Professional service by experienced technicians.</p>
          </div>
          <div class="rounded-2xl border border-neutral-200 bg-neutral-50 p-4">
            <p class="text-xs uppercase tracking-[0.16em] text-neutral-500">04</p>
            <h3 class="mt-1 text-base font-semibold text-neutral-900">Delivery</h3>
            <p class="mt-2 text-sm text-neutral-600">Quality check and vehicle delivery.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="px-4 pb-10 pt-6 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-6xl rounded-3xl border border-neutral-200 bg-neutral-900 p-6 text-white shadow-soft sm:p-8">
        <h2 class="text-2xl font-semibold sm:text-3xl">Need Professional Service?</h2>
        <p class="mt-3 max-w-2xl text-sm text-neutral-200 sm:text-base">
          Get in touch with us today. Our team is ready to help you with any automobile service needs.
        </p>
        <div class="mt-5 flex flex-wrap gap-3">
          <a href="tel:9756544613" class="inline-flex h-11 items-center rounded-full bg-white px-5 text-sm font-semibold text-neutral-900">Call 9756544613</a>
          <a href="/contact" class="inline-flex h-11 items-center rounded-full border border-white/60 px-5 text-sm font-semibold text-white">Contact Us</a>
        </div>
      </div>
    </section>

    <Footer client:load />
  </main>
</BaseLayout>

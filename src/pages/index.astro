---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ServiceCard from '../components/ServiceCard.astro';
import '../styles/global.css';
---

<BaseLayout 
  title="Warsi Service Center | Car & Bike Service Since 1962 | Denting Painting Mechanical Repairs"
  description="Professional automobile service center since 1962. Expert denting, painting, mechanical repairs, custom modding, AC works, and complete vehicle care for cars, bikes, and scooters. Call 9756544613 today!"
  keywords="car service, bike service, automobile repair, denting painting, mechanical repairs, car modification, bike modification, AC repair, car wash, teflon coating, custom body kits, suspension setup, engine tuning, vehicle service center, auto repair shop, car garage, bike garage, warsi service center"
  currentPath="/"
>
  <Header />
  
  <!-- Hero Section -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-20">
    <!-- Animated background pattern -->
    <div class="absolute inset-0 grid-pattern opacity-40"></div>
    
    <!-- Gradient overlay -->
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-workshop-darker/50 to-workshop-darker"></div>
    
    <div class="container-custom px-4 relative z-10">
      <div class="max-w-4xl mx-auto text-center">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-workshop-gray border border-accent-navy/30 rounded-full mb-8 animate-fade-in">
          <span class="w-2 h-2 bg-accent-navy rounded-full animate-pulse"></span>
          <span class="text-sm text-gray-300">Professional Service Since 1962</span>
        </div>

        <!-- Main heading -->
        <h1 class="text-5xl md:text-7xl font-display font-bold text-white mb-6 animate-slide-up">
          Warsi Service <span class="gradient-text">Center</span>
        </h1>
        
        <p class="text-xl md:text-2xl text-gray-400 mb-8 animate-slide-up" style="animation-delay: 0.1s;">
          Your trusted partner for complete automobile care
        </p>
        
        <p class="text-gray-400 max-w-2xl mx-auto mb-12 animate-slide-up" style="animation-delay: 0.2s;">
          Expert denting, painting, mechanical repairs, custom modding, and comprehensive services for cars, bikes, and scooters. Professional quality guaranteed.
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center animate-slide-up" style="animation-delay: 0.3s;">
          <a href="tel:9756544613" class="btn btn-primary text-lg">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Call 9756544613
          </a>
          
          <a href="/services" class="btn btn-outline text-lg">
            View All Services
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
        </div>

        <!-- Quick stats -->
        <div class="grid grid-cols-3 gap-8 max-w-2xl mx-auto mt-20 animate-slide-up" style="animation-delay: 0.4s;">
          <div class="text-center">
            <div class="text-3xl md:text-4xl font-display font-bold gradient-text mb-2">15+</div>
            <div class="text-sm text-gray-400">Services Offered</div>
          </div>
          <div class="text-center">
            <div class="text-3xl md:text-4xl font-display font-bold gradient-text mb-2">100%</div>
            <div class="text-sm text-gray-400">Quality Work</div>
          </div>
          <div class="text-center">
            <div class="text-3xl md:text-4xl font-display font-bold gradient-text mb-2">24/7</div>
            <div class="text-sm text-gray-400">Support</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-accent-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </section>

  <!-- Featured Services Section -->
  <section class="section bg-workshop-dark">
    <div class="container-custom px-4">
      <div class="text-center mb-16">
        <div class="inline-block accent-line mb-4"></div>
        <h2 class="text-4xl md:text-5xl font-display font-bold text-white mb-4">
          Our <span class="gradient-text">Services</span>
        </h2>
        <p class="text-gray-400 max-w-2xl mx-auto">
          Comprehensive automobile solutions for all your vehicle needs
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
        <ServiceCard 
          icon="🎨"
          title="Denting & Painting"
          description="Expert denting removal and premium quality painting for flawless finish"
        />
        
        <ServiceCard 
          icon="🔧"
          title="Mechanical Repairs"
          description="Complete mechanical diagnostics and repairs by experienced technicians"
        />
        
        <ServiceCard 
          icon="⚡"
          title="Welding Services"
          description="Electric welding for steel, aluminum & brass, plus gas and plastic welding"
        />
        
        <ServiceCard 
          icon="✨"
          title="Washing & Polishing"
          description="Premium car wash and polishing services for showroom shine"
        />
        
        <ServiceCard 
          icon="🛡️"
          title="Teflon Coating"
          description="Advanced protective coating for long-lasting paint protection"
        />
        
        <ServiceCard 
          icon="💡"
          title="Electrical Work"
          description="Complete electrical system diagnostics and repairs"
        />
        
        <ServiceCard 
          icon="🏎️"
          title="Custom Modding"
          description="Custom body kits, modifications, and performance upgrades"
        />
        
        <ServiceCard 
          icon="🔩"
          title="Suspension Setup"
          description="Custom suspension tuning and installation services"
        />
        
        <ServiceCard 
          icon="❄️"
          title="AC Works"
          description="Complete AC servicing, repairs, and gas refill services"
        />
      </div>

      <div class="text-center animate-on-scroll">
        <a href="/services" class="btn btn-primary text-lg">
          View All Services
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Why Choose Us Section -->
  <section class="section bg-workshop-darker">
    <div class="container-custom px-4">
      <div class="text-center mb-16">
        <div class="inline-block accent-line mb-4"></div>
        <h2 class="text-4xl md:text-5xl font-display font-bold text-white mb-4">
          Why <span class="gradient-text">Choose Us</span>
        </h2>
        <p class="text-gray-400 max-w-2xl mx-auto">
          Professional service you can trust
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="text-center animate-on-scroll group cursor-pointer">
          <div class="w-16 h-16 bg-accent-navy rounded-full flex items-center justify-center mx-auto mb-4 group-hover:scale-110 group-hover:shadow-lg group-hover:shadow-accent-navy/50 transition-all duration-300">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="font-display text-xl font-semibold text-white mb-2">Quality Work</h3>
          <p class="text-gray-400 text-sm">Professional service with guaranteed quality</p>
        </div>

        <div class="text-center animate-on-scroll group cursor-pointer" style="animation-delay: 0.1s;">
          <div class="w-16 h-16 bg-accent-navy-light rounded-full flex items-center justify-center mx-auto mb-4 group-hover:scale-110 group-hover:shadow-lg group-hover:shadow-accent-navy-light/50 transition-all duration-300">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="font-display text-xl font-semibold text-white mb-2">Fast Service</h3>
          <p class="text-gray-400 text-sm">Quick turnaround without compromising quality</p>
        </div>

        <div class="text-center animate-on-scroll group cursor-pointer" style="animation-delay: 0.2s;">
          <div class="w-16 h-16 bg-accent-navy-light rounded-full flex items-center justify-center mx-auto mb-4 group-hover:scale-110 group-hover:shadow-lg group-hover:shadow-accent-navy-light/50 transition-all duration-300">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
          <h3 class="font-display text-xl font-semibold text-white mb-2">Fair Pricing</h3>
          <p class="text-gray-400 text-sm">Transparent pricing with no hidden costs</p>
        </div>

        <div class="text-center animate-on-scroll group cursor-pointer" style="animation-delay: 0.3s;">
          <div class="w-16 h-16 bg-accent-navy rounded-full flex items-center justify-center mx-auto mb-4 group-hover:scale-110 group-hover:shadow-lg group-hover:shadow-accent-navy/50 transition-all duration-300">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 10h4.764a2 2 0 011.789 2.894l-3.5 7A2 2 0 0115.263 21h-4.017c-.163 0-.326-.02-.485-.06L7 20m7-10V5a2 2 0 00-2-2h-.095c-.5 0-.905.405-.905.905 0 .714-.211 1.412-.608 2.006L7 11v9m7-10h-2M7 20H5a2 2 0 01-2-2v-6a2 2 0 012-2h2.5" />
            </svg>
          </div>
          <h3 class="font-display text-xl font-semibold text-white mb-2">Expert Team</h3>
          <p class="text-gray-400 text-sm">Experienced professionals you can trust</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="section bg-workshop-dark">
    <div class="container-custom px-4">
      <div class="max-w-4xl mx-auto text-center card glow-orange p-12 animate-on-scroll relative overflow-hidden">
        <!-- Animated background shine -->
        <div class="absolute inset-0 shimmer opacity-50"></div>
        
        <div class="relative z-10">
        <h2 class="text-3xl md:text-4xl font-display font-bold text-white mb-4">
          Ready to Get Your Vehicle Serviced?
        </h2>
        <p class="text-gray-400 mb-8 max-w-2xl mx-auto">
          Contact us today for professional automobile service. We handle everything from routine maintenance to custom modifications.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="tel:9756544613" class="btn btn-primary text-lg">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Call 9756544613
          </a>
          <a href="/contact" class="btn btn-secondary text-lg">
            Contact Us
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
        </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

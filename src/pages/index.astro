---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Hero } from '@/components/ui/animated-hero';
import { FeaturesSectionWithHoverEffects } from '@/components/ui/feature-section-with-hover-effects';
import RadialOrbitalTimeline from '@/components/ui/radial-orbital-timeline';
import { radialTimelineData } from '@/data/timeline';
---

<BaseLayout
  title="Warsi Service Center | Automobile Service Since 1962"
  description="Professional automobile service center in Nainital for denting, painting, mechanical repairs, welding, AC work, detailing, and custom modification services."
>
  <main class="min-h-screen bg-hero-wash">
    <section class="px-4 pt-6 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-6xl px-1 sm:px-2">
        <Hero client:load />
      </div>
    </section>

    <FeaturesSectionWithHoverEffects client:load />

    <RadialOrbitalTimeline client:load timelineData={radialTimelineData} />
  </main>
</BaseLayout>

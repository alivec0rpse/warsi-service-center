---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<BaseLayout 
  title="Contact Us | Warsi Service Center"
  description="Get in touch with Warsi Service Center. Call 9756544613 or email adiwarsi953@gmail.com for professional automobile service."
  currentPath="/contact"
>
  <Header />
  
  <!-- Hero Section -->
  <section class="relative pt-32 pb-16 overflow-hidden">
    <div class="absolute inset-0 grid-pattern opacity-40"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent to-workshop-darker"></div>
    
    <div class="container-custom px-4 relative z-10">
      <div class="max-w-3xl mx-auto text-center">
        <div class="inline-block accent-line mb-6"></div>
        <h1 class="text-5xl md:text-6xl font-display font-bold text-white mb-6 animate-fade-in">
          Get In <span class="gradient-text">Touch</span>
        </h1>
        <p class="text-xl text-gray-400 mb-4 animate-fade-in">
          Ready to service your vehicle? We're here to help!
        </p>
        <p class="text-gray-400 animate-fade-in">
          Contact us today for professional automobile service. Our team is ready to assist you with any questions or service needs.
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Methods Section -->
  <section class="section bg-workshop-darker">
    <div class="container-custom px-4">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto">
        <!-- Phone Contact -->
        <a 
          href="tel:9756544613"
          class="card card-hover p-8 group animate-on-scroll"
        >
          <div class="flex items-start gap-6">
            <div class="flex-shrink-0 w-16 h-16 bg-accent-navy rounded-full flex items-center justify-center group-hover:scale-110 transition-transform">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div class="flex-grow">
              <h3 class="font-display text-2xl font-semibold text-white mb-2 group-hover:text-accent-navy-light transition-colors">
                Call Us
              </h3>
              <p class="text-gray-400 mb-4">
                Speak directly with our team for immediate assistance
              </p>
              <p class="text-2xl font-display font-bold gradient-text">
                9756544613
              </p>
            </div>
          </div>
        </a>

        <!-- Email Contact -->
        <a 
          href="mailto:adiwarsi953@gmail.com"
          class="card card-hover p-8 group animate-on-scroll"
          style="animation-delay: 0.1s;"
        >
          <div class="flex items-start gap-6">
            <div class="flex-shrink-0 w-16 h-16 bg-accent-navy-light rounded-full flex items-center justify-center group-hover:scale-110 transition-transform">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div class="flex-grow">
              <h3 class="font-display text-2xl font-semibold text-white mb-2 group-hover:text-accent-navy-light transition-colors">
                Email Us
              </h3>
              <p class="text-gray-400 mb-4">
                Send us a detailed message about your service needs
              </p>
              <p class="text-lg font-display font-semibold gradient-text break-all">
                adiwarsi953@gmail.com
              </p>
            </div>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Quick Actions Section -->
  <section class="section bg-workshop-dark">
    <div class="container-custom px-4">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-12">
          <div class="inline-block accent-line mb-4"></div>
          <h2 class="text-4xl md:text-5xl font-display font-bold text-white mb-4">
            Quick <span class="gradient-text">Actions</span>
          </h2>
          <p class="text-gray-400">
            Choose the best way to reach us
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          <a 
            href="tel:9756544613"
            class="btn btn-primary text-lg p-6 justify-center animate-on-scroll"
          >
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Call 9756544613
          </a>

          <a 
            href="mailto:adiwarsi953@gmail.com"
            class="btn btn-outline text-lg p-6 justify-center animate-on-scroll"
            style="animation-delay: 0.1s;"
          >
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            Send Email
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Business Hours & Info Section -->
  <section class="section bg-workshop-darker">
    <div class="container-custom px-4">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-12">
          <div class="inline-block accent-line mb-4"></div>
          <h2 class="text-4xl md:text-5xl font-display font-bold text-white mb-4">
            Visit <span class="gradient-text">Us</span>
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <!-- Contact Information -->
          <div class="card p-8 animate-on-scroll">
            <h3 class="font-display text-2xl font-semibold text-white mb-6 flex items-center gap-3">
              <svg class="w-6 h-6 text-accent-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              Contact Information
            </h3>
            
            <div class="space-y-6">
              <div>
                <p class="text-gray-400 text-sm mb-2">Phone</p>
                <a href="tel:9756544613" class="text-white text-lg font-semibold hover:text-accent-navy-light transition-colors">
                  9756544613
                </a>
              </div>

              <div>
                <p class="text-gray-400 text-sm mb-2">Email</p>
                <a href="mailto:adiwarsi953@gmail.com" class="text-white text-lg font-semibold hover:text-accent-navy-light transition-colors break-all">
                  adiwarsi953@gmail.com
                </a>
              </div>

              <div>
                <p class="text-gray-400 text-sm mb-2">Website</p>
                <a href="https://warsi.qzz.io" class="text-white text-lg font-semibold hover:text-accent-navy-light transition-colors break-all">
                  warsi.qzz.io
                </a>
              </div>
            </div>
          </div>

          <!-- What to Expect -->
          <div class="card p-8 animate-on-scroll" style="animation-delay: 0.1s;">
            <h3 class="font-display text-2xl font-semibold text-white mb-6 flex items-center gap-3">
              <svg class="w-6 h-6 text-accent-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              What to Expect
            </h3>
            
            <ul class="space-y-4">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-accent-navy flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-gray-300">Quick response to your inquiries</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-accent-navy flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-gray-300">Professional consultation</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-accent-navy flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-gray-300">Transparent pricing estimates</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-accent-navy flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-gray-300">Detailed service explanations</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-accent-navy flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-gray-300">Friendly and helpful staff</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Overview CTA -->
  <section class="section bg-workshop-dark">
    <div class="container-custom px-4">
      <div class="max-w-4xl mx-auto text-center card glow-orange p-12 animate-on-scroll">
        <h2 class="text-3xl md:text-4xl font-display font-bold text-white mb-4">
          Explore Our Services
        </h2>
        <p class="text-gray-400 mb-8 max-w-2xl mx-auto">
          Discover the full range of professional automobile services we offer for cars, bikes, and scooters.
        </p>
        <a href="/services" class="btn btn-primary text-lg">
          View All Services
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

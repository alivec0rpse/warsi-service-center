---
// Header component with navigation
const currentPath = Astro.url.pathname;

const navItems = [
  { name: 'Home', path: '/' },
  { name: 'Services', path: '/services' },
  { name: 'Contact', path: '/contact' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-workshop-darker/95 backdrop-blur-md border-b border-workshop-border">
  <nav class="container-custom px-4 py-4">
    <div class="flex items-center justify-between">
      <!-- Logo/Brand -->
      <a href="/" class="flex items-center gap-3 group">
        <img 
          src="/logo.png" 
          alt="Warsi Service Center Logo" 
          class="h-12 w-auto object-contain"
        />
        <div>
          <h1 class="font-display text-xl font-bold text-white group-hover:text-accent-navy-light transition-colors">
            Warsi Service Center
          </h1>
        </div>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-8">
        {navItems.map(item => (
          <a 
            href={item.path}
            class={`font-medium transition-colors ${
              currentPath === item.path 
                ? 'text-accent-orange' 
                : 'text-gray-300 hover:text-accent-orange'
            }`}
          >
            {item.name}
          </a>
        ))}
        <a 
          href="tel:9756544613" 
          class="btn btn-primary"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Call Now
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button 
        id="mobile-menu-btn"
        class="md:hidden p-2 text-gray-300 hover:text-accent-navy-light transition-colors"
        aria-label="Toggle menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile Navigation -->
    <div id="mobile-menu" class="hidden md:hidden pt-4 pb-2">
      <div class="flex flex-col gap-4">
        {navItems.map(item => (
          <a 
            href={item.path}
            class={`font-medium transition-colors ${
              currentPath === item.path 
                ? 'text-accent-orange' 
                : 'text-gray-300 hover:text-accent-orange'
            }`}
          >
            {item.name}
          </a>
        ))}
        <a 
          href="tel:9756544613" 
          class="btn btn-primary w-full justify-center"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Call Now
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
  // Mobile menu toggle
  document.addEventListener('DOMContentLoaded', () => {
    const menuBtn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    
    menuBtn?.addEventListener('click', () => {
      menu?.classList.toggle('hidden');
    });
  });
</script>

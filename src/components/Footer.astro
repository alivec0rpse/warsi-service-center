---
// Footer component with business info and quick links
---

<footer class="bg-workshop-dark border-t border-workshop-border mt-auto">
  <div class="container-custom px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
      <!-- Brand Info -->
      <div>
        <div class="flex items-center gap-3 mb-4">
          <img 
            src="/logo.png" 
            alt="Warsi Service Center Logo" 
            class="h-10 w-auto object-contain"
          />
          <h3 class="font-display text-xl font-bold text-white">Warsi Service Center</h3>
        </div>
        <p class="text-gray-400 mb-4">
          Professional automobile service center offering comprehensive solutions for cars, bikes, and scooters.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="font-display text-lg font-semibold text-white mb-4">Quick Links</h4>
        <ul class="space-y-2">
          <li>
            <a href="/" class="text-gray-400 hover:text-accent-navy-light transition-colors">Home</a>
          </li>
          <li>
            <a href="/services" class="text-gray-400 hover:text-accent-navy-light transition-colors">Services</a>
          </li>
          <li>
            <a href="/contact" class="text-gray-400 hover:text-accent-navy-light transition-colors">Contact</a>
          </li>
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h4 class="font-display text-lg font-semibold text-white mb-4">Get in Touch</h4>
        <ul class="space-y-3">
          <li>
            <a 
              href="tel:9756544613" 
              class="flex items-center gap-2 text-gray-400 hover:text-accent-navy-light transition-colors group"
            >
              <svg class="w-5 h-5 text-accent-navy group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              9756544613
            </a>
          </li>
          <li>
            <a 
              href="mailto:adiwarsi953@gmail.com" 
              class="flex items-center gap-2 text-gray-400 hover:text-accent-navy-light transition-colors group"
            >
              <svg class="w-5 h-5 text-accent-navy group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              adiwarsi953@gmail.com
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="pt-8 border-t border-workshop-border">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-gray-500 text-sm">
          © {new Date().getFullYear()} Warsi Service Center. All rights reserved.
        </p>
        <p class="text-gray-500 text-sm">
          Professional service for cars, bikes & scooters
        </p>
      </div>
    </div>
  </div>
</footer>

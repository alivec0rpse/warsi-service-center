---
// Service Card Component
interface Props {
  icon: string;
  title: string;
  description: string;
}

const { icon, title, description } = Astro.props;
---

<div class="card card-hover animate-on-scroll group relative overflow-hidden">
  <!-- Background decoration -->
  <div class="absolute top-0 right-0 w-32 h-32 bg-accent-navy/5 rounded-full -mr-16 -mt-16 group-hover:scale-150 transition-transform duration-500"></div>
  
  <div class="flex items-start gap-4 relative z-10">
    <div class="flex-shrink-0 w-12 h-12 bg-accent-navy rounded-lg flex items-center justify-center group-hover:bg-accent-navy-light group-hover:rotate-6 transition-all duration-300">
      <span class="text-2xl">{icon}</span>
    </div>
    <div>
      <h3 class="font-display text-lg font-semibold text-white mb-2 group-hover:text-accent-navy-light transition-colors">{title}</h3>
      <p class="text-gray-400 text-sm leading-relaxed">{description}</p>
    </div>
  </div>
</div>

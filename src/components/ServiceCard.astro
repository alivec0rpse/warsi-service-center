---
// Service Card Component
interface Props {
  icon: string;
  title: string;
  description: string;
}

const { icon, title, description } = Astro.props;
---

<div class="card card-hover animate-on-scroll">
  <div class="flex items-start gap-4">
    <div class="flex-shrink-0 w-12 h-12 bg-accent-navy rounded-lg flex items-center justify-center">
      <span class="text-2xl">{icon}</span>
    </div>
    <div>
      <h3 class="font-display text-lg font-semibold text-white mb-2">{title}</h3>
      <p class="text-gray-400 text-sm leading-relaxed">{description}</p>
    </div>
  </div>
</div>
